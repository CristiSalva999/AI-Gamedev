# ---------------------------------------------------------------------------
# AI GameDev pipeline configuration (copy to server/.env or export in shell)
# ---------------------------------------------------------------------------

# Backend orchestration server
PORT=3001

# Where packaged games, zips, and .glb assets are written
# DATA_DIR=server/data
# GAMES_DIR=server/data/games

# Local LLM (LM Studio exposes an OpenAI-compatible server)
# Start it from LM Studio -> "Local Server" -> Start Server.
LLM_BASE_URL=http://localhost:1234/v1
# LM Studio does not require a real key; any string works.
LLM_API_KEY=lm-studio
LLM_MODEL=gemma-4-26b-a4b-it

# When the LLM endpoint is unreachable the server falls back to a deterministic
# mock so the pipeline stays fully runnable offline. Set to "false" to force
# real calls and surface connection errors instead.
LLM_ALLOW_MOCK_FALLBACK=true

# Optional: path to a Blender binary for headless asset export.
# When unset/unavailable the pipeline writes procedural .glb files instead.
# BLENDER_BIN=blender

# Frontend dev server -> backend URL (used by Vite proxy / client)
VITE_API_BASE_URL=http://localhost:3001
