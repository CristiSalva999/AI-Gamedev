# ---------------------------------------------------------------------------
# AI GameDev pipeline configuration (copy to server/.env or export in shell)
# ---------------------------------------------------------------------------

# Backend orchestration server
PORT=3001

# Where packaged games, zips, and .glb assets are written
# DATA_DIR=server/data
# GAMES_DIR=server/data/games

# Local LLM (LM Studio exposes an OpenAI-compatible server)
# Start it from LM Studio -> "Local Server" -> Start Server.
LLM_BASE_URL=http://localhost:1234/v1
# LM Studio does not require a real key; any string works.
LLM_API_KEY=lm-studio
LLM_MODEL=gemma-4-26b-a4b-it

# When the LLM endpoint is unreachable the server falls back to a deterministic
# mock so the pipeline stays fully runnable offline. The mock is setting-aware
# (motifs): a "dwarvy archery" shooter gets targets/hay bales, not sci-fi hangar
# props. Set to "false" to force real calls and surface connection errors instead.
LLM_ALLOW_MOCK_FALLBACK=true

# Max time (ms) to wait for a single LLM completion before aborting to the mock.
# Raise this for slow local/reasoning models — too low a value aborts mid-answer
# and you'll see "falling back to mock (This operation was aborted)".
# Gemma-class local models often need 120s–300s per design/world call.
# LLM_TIMEOUT_MS=180000

# Optional: path to a Blender binary for headless asset export.
# Copy this file to server/.env (recommended) or .env at the repo root.
# The server loads those files on startup — setting vars only in the shell is optional.
#
# On Windows the installer usually does NOT add `blender` to PATH. Set the full
# path to blender.exe (example for Blender 5.2 LTS):
# BLENDER_BIN=C:\Program Files\Blender Foundation\Blender 5.2\blender.exe
# The server also auto-probes Program Files\Blender Foundation\Blender *\.

# Frontend API base. Leave EMPTY in Cursor Cloud / Vite so the browser uses
# same-origin `/api` (proxied to :3001). Only set this when the UI talks to a
# backend on a different origin.
# VITE_API_BASE_URL=
