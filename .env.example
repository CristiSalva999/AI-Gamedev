# ---------------------------------------------------------------------------
# AI GameDev — copy this file to `server/.env` (or repo-root `.env`) on your PC
# ---------------------------------------------------------------------------

PORT=3001

# LM Studio OpenAI-compatible server
# Pi.dev may store "http://127.0.0.1:1234" (no /v1) — both forms work.
LLM_BASE_URL=http://127.0.0.1:1234/v1
LLM_API_KEY=lm-studio
LLM_MODEL=gemma-4-26b-a4b-it

# Keep true while iterating; set false to surface connection errors loudly.
LLM_ALLOW_MOCK_FALLBACK=true

# Gemma 26B can be slow on first tokens — allow up to 2 minutes.
LLM_TIMEOUT_MS=120000

# Windows example (adjust version/path to your install):
# BLENDER_BIN=C:\Program Files\Blender Foundation\Blender 4.2\blender.exe
# macOS/Linux if blender is on PATH:
# BLENDER_BIN=blender

# Leave empty so the Vite UI uses same-origin /api (recommended).
# VITE_API_BASE_URL=
